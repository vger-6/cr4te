{% import "partials/_utils.html.j2" as utils %}
{% import "partials/_media_badges.html.j2" as media_badges %}
{% import "partials/_empty_state.html.j2" as empty_states %}

<!DOCTYPE html>
{% include "partials/_document_open.html.j2" %}
{% include "partials/_document_head.html.j2" %}
<body data-default-theme="{{ default_theme.css_class }}">

<div class="page-container">
  {% include "partials/_page_header.html.j2" %}

  <main class="page-content" aria-labelledby="page-title">
  <h1 id="page-title" class="visually-hidden">{{ page_shell.title }}</h1>
  {% if creator_entries %}
    {% set search_text_placeholder = site_labels.controls.search_placeholder_format | format_phrase(creators=site_labels.entity.creators, projects=site_labels.entity.projects, tags=site_labels.entity.tags) %}
    {% include "partials/_search_bar.html.j2" %}
  {% endif %}

  {% set portrait_image_cards = site_rendering.portraits.visibility == PortraitVisibility.ALL %}
  {% set image_gallery_class = utils.get_image_gallery_class(ImageGalleryBuildingStrategy, site_rendering.galleries.creator_cards.building_strategy) if portrait_image_cards else 'creator-card-grid' %}
  {% set aspect_ratio = site_rendering.galleries.creator_cards.aspect_ratio or '1/1' %}

  <div class="overview-layout">

    <div class="section-box">
      <div class="section-content">
        {% if creator_entries %}
        <div class="{{ image_gallery_class }} card-gallery"
             id="imageGallery"
             data-image-max-height="{{ gallery_image_max_height }}"
             data-page-size="{{ site_rendering.galleries.creator_cards.page_size }}"
             data-previous-label="{{ site_labels.controls.previous }}"
             data-next-label="{{ site_labels.controls.next }}"
             data-aspect-ratio="{{ aspect_ratio }}">
          {% for creator in creator_entries %}
            {% if not portrait_image_cards %}
          <div class="image-wrapper image-card creator-text-card"
               data-search-text="{{ creator.search_text }}">
            <a href="{{ creator.rel_html_path }}" title="{{ creator.name }}" class="creator-text-card__content">
              <span class="creator-text-card__name">{{ creator.name }}</span>
              {% if creator.project_count_summary or creator.media_count_summary %}
                <span class="creator-text-card__counts">
                {% if creator.project_count_summary %}
                  <small class="creator-text-card__summary creator-text-card__project-summary">{{ creator.project_count_summary }}</small>
                {% endif %}
                {% if creator.media_count_summary %}
                  <small class="creator-text-card__summary creator-text-card__media-summary">{{ creator.media_count_summary }}</small>
                {% endif %}
                </span>
              {% endif %}
            </a>
          </div>
            {% else %}
          <div class="image-wrapper image-card"
               data-search-text="{{ creator.search_text }}"
               data-width="{{ creator.image_wrapper_width }}"
               data-height="{{ creator.image_wrapper_height }}">
            <a href="{{ creator.rel_html_path }}" title="{{ creator.name }}">
                <img class="card-image" src="{{ creator.rel_thumbnail_path }}" alt="{{ site_labels.accessibility.creator_thumbnail_description_format | format_phrase(creator=creator.name) }}" loading="lazy">
                {{ media_badges.creator_badges(creator.project_count, creator.media_counts, site_labels) }}
              <div class=image-caption>
                <span>{{ creator.name }}</span>
              </div>
            </a>
          </div>
            {% endif %}
          {% endfor %}
        </div>
        {{ empty_states.render(site_labels.empty_states.no_search_results, "empty-state--search", hidden=true, live=true) }}
        {% else %}
          {% set no_creators_message = site_labels.empty_states.no_creators_format | format_phrase(creators=site_labels.entity.creators) %}
          {{ empty_states.render(no_creators_message) }}
        {% endif %}
      </div>
    </div>

  </div>
  </main>
</div>

<script src="assets/js/utils.js" defer></script>
<script src="assets/js/overflow_tooltips.js" defer></script>
<script src="assets/js/pagination.js" defer></script>
<script src="assets/js/search_filter.js" defer></script>
<script src="assets/js/aspect_gallery_builder.js" defer></script>
<script src="assets/js/justified_gallery_builder.js" defer></script>
<script src="assets/js/theme_selector.js" defer></script>

</body>
</html>

