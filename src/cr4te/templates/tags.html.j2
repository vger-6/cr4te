{% import "partials/_empty_state.html.j2" as empty_states %}

<!DOCTYPE html>
{% include "partials/_document_open.html.j2" %}
{% include "partials/_document_head.html.j2" %}
<body data-default-theme="{{ default_theme.css_class }}">

<div class="page-container">
  {% include "partials/_page_header.html.j2" %}

  <main class="page-content">
  <h1 class="page-title">{{ page_shell.title }}</h1>

  <div class="overview-layout">

    <div class="section-box">
      <div class="section-content{% if tags.groups %} tag-list{% endif %}">

        {% if tags.groups %}
        {% for group in tags.groups %}
        <div class="tag-category" id="{{ group.category | lower | replace(' ', '-') }}">
          <span class="tag-category-label data-label">{{ group.category }}</span>
          {% for tag in group.tags %}
            <a class="tag" href="index.html?tag={{ (group.category ~ ':' ~ tag) | urlencode }}">{{ tag }}</a>
          {% endfor %}
        </div>
        {% endfor %}
        {% else %}
          {% set no_tags_message = site_labels.empty_states.no_tags_format | format_phrase(tags=site_labels.entity.tags) %}
          {{ empty_states.render(no_tags_message) }}
        {% endif %}

     </div>
    </div>

  </div>
  </main>
</div>

<script src="assets/js/utils.js" defer></script>
<script src="assets/js/theme_selector.js" defer></script>

</body>
</html>

