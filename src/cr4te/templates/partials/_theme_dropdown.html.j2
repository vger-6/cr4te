<div style="float: right;">
  <div class="theme-dropdown">
    <button class="theme-button" id="theme-toggle">Themes</button>
    <div class="theme-panel" id="theme-panel">
      {% for theme in themes %}
      <div class="theme-option" data-theme="{{ theme.css_class }}">{{ theme.display_name }}</div>
      {% endfor %}
    </div>
  </div>
</div>

