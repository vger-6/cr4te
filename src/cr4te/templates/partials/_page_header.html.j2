<div class="page-header">
  <nav class="top-link" aria-label="Primary">
    <a class="site-logo-link"
       href="{{ page_shell.navigation_items[0].href }}"
       aria-label="{{ site_labels.accessibility.site_logo_overview_label_format | format_phrase(overview=page_shell.navigation_items[0].label) }}">
      <img class="site-logo"
           src="{{ path_to_root | default('') }}assets/favicon.svg"
           alt=""
           width="24"
           height="24">
    </a>
    {% set primary_navigation_items = page_shell.navigation_items | rejectattr('starts_section') | list %}
    {% set section_navigation_items = page_shell.navigation_items | selectattr('starts_section') | list %}
    <div class="breadcrumb-list">
      {% for item in primary_navigation_items %}
        {% if not loop.first %}<span class="breadcrumb-separator" aria-hidden="true">&middot;</span>{% endif %}
        {% if item.current %}
          <span class="nav-current" aria-current="page">{{ item.label }}</span>
        {% else %}
          <a href="{{ item.href }}">{{ item.label }}</a>
        {% endif %}
      {% endfor %}
    </div>
    {% if section_navigation_items %}
    <span class="breadcrumb-section">
      <span class="breadcrumb-separator breadcrumb-separator--section" aria-hidden="true">|</span>
      {% for item in section_navigation_items %}
        {% if not loop.first %}<span class="breadcrumb-separator" aria-hidden="true">&middot;</span>{% endif %}
        {% if item.current %}
          <span class="nav-current" aria-current="page">{{ item.label }}</span>
        {% else %}
          <a href="{{ item.href }}">{{ item.label }}</a>
        {% endif %}
      {% endfor %}
    </span>
    {% endif %}
    {% include "partials/_theme_dropdown.html.j2" %}
  </nav>
  <h1 class="page-title">{{ page_shell.title }}</h1>
</div>
