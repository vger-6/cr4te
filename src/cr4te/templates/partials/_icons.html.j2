{# templates/partials/_icons.html.j2 #}
{% macro play_pause_icon() %}
<svg viewBox="0 0 24 24" class="icon play-toggle-icon">
  <path d="M8 5v14l11-7z" data-play></path>
  <path d="M6 19h4V5H6v14zm8 0h4V5h-4v14z" data-pause style="display: none;"></path>
</svg>
{% endmacro %}

{% macro stop_icon() %}
<svg viewBox="0 0 24 24" class="icon stop-icon">
  <rect x="6" y="6" width="12" height="12"/>
</svg>
{% endmacro %}

{% macro prev_icon() %}
<svg viewBox="0 0 24 24" class="icon prev-icon">
  <rect x="5" y="5" width="2" height="14"/>
  <path d="M18 5v14l-10-7z"/>
</svg>
{% endmacro %}

{% macro next_icon() %}
<svg viewBox="0 0 24 24" class="icon next-icon">
  <path d="M6 5v14l10-7z"/>
  <rect x="17" y="5" width="2" height="14"/>
</svg>
{% endmacro %}

{% macro volume_icon() %}
<svg viewBox="0 0 24 24" class="icon volume-icon" fill="currentColor">
  <path d="M11 5L6 9H2v6h4l5 4V5z" />
  <rect x="13" y="11" width="1.5" height="2" rx="0.5" />
  <rect x="16" y="9" width="1.5" height="6" rx="0.5" />
  <rect x="19" y="7" width="1.5" height="10" rx="0.5" />
</svg>
{% endmacro %}

{% macro fullscreen_icon() %}
<svg viewBox="0 0 24 24" class="icon fullscreen-icon">
  <path d="M4 4h6v2H6v4H4V4zm16 0v6h-2V6h-4V4h6zm-6 16v-2h4v-4h2v6h-6zm-6 0H4v-6h2v4h4v2z"/>
</svg>
{% endmacro %}

{% macro captions_on_icon() %}
<svg viewBox="0 0 24 24" class="icon image-caption-icon">
  <!-- Image frame -->
  <path
    d="M6 8h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2z"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  />

  <!-- Sun -->
  <circle cx="9" cy="13" r="1.5"/>

  <!-- Mountains -->
  <path d="M6 18l3-3 3 2 3-3 3 4H6z"/>

  <!-- Caption line -->
  <rect x="6" y="22" width="12" height="2" rx="1"/>
</svg>
{% endmacro %}

{% macro captions_off_icon() %}
<svg viewBox="0 0 24 24" class="icon image-caption-icon">
  <!-- Image frame -->
  <path
    d="M6 8h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2z"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  />

  <!-- Sun -->
  <circle cx="9" cy="13" r="1.5"/>

  <!-- Mountains -->
  <path d="M6 18l3-3 3 2 3-3 3 4H6z"/>
</svg>
{% endmacro %}
